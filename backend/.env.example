PROJECT_NAME=FAST Ecom API
APP_ENV=development
DEBUG=true
API_V1_STR=/api/v1

POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=fast_ecom

# Optional: override the assembled PostgreSQL URL with a single DSN.
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/fast_ecom

JWT_SECRET_KEY=change-this-jwt-secret-key-in-production-123456
JWT_ALGORITHM=HS256
JWT_ISSUER=fast-ecom-api
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
